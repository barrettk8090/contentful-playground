# Copy to .env and fill in values from Contentful → Settings → API keys
# https://www.contentful.com/developers/docs/references/content-delivery-api/

VITE_CONTENTFUL_SPACE_ID=
VITE_CONTENTFUL_CDA_TOKEN=
VITE_CONTENTFUL_CPA_TOKEN=

# Optional; defaults to master
# VITE_CONTENTFUL_ENVIRONMENT=master

# Optional: pre-select a content type in Site preview (content type ID from Content Model)
# VITE_SITE_PREVIEW_CONTENT_TYPE=
